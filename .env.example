# Copia a .env para desarrollo local. En Railway se configuran como variables del servicio.
DATABASE_URL="postgresql://usuario:password@host:5432/railway"
JWT_SECRET="genera-uno-largo-y-aleatorio"
ADMIN_USER="orientador"
ADMIN_PASSWORD="cambia-esta-clave"
GEMINI_API_KEY="tu-api-key-de-google-ai-studio"
# Modelo compatible con salida JSON estructurada.
GEMINI_MODEL="gemini-2.5-flash"
# Opcional: total de estudiantes esperado para calcular % de participación
EXPECTED_STUDENTS=0
